{
  "name": "bask-start",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/write-build-info.mjs",
    "check": "tsc --noEmit -p tsconfig.json",
    "state:snapshot": "npm run build && node dist/dev/state-snapshot.js",
    "simulate:month": "npm run build && node dist/dev/monthly-simulation.js",
    "simulate:cohorts": "npm run build && node dist/dev/two-month-simulation.js",
    "test": "npm run test:contract",
    "test:contract": "npm run build && node --test dist/__tests__/frontend-readiness-contract.test.js",
    "start": "node dist/server.js"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/pg": "^8.20.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
